# Template - copiá a .env y completá. NUNCA commitees el .env real.
# Ejemplos usan IPs de RFC 5737 (192.0.2.0/24 - documentation) y dominio example.local.

# ===== AD / LDAP =====
LDAP_HOST=192.0.2.10
LDAP_PORT=389
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_DN=CN=svc-soar,OU=Services,OU=Tech,OU=Example Corp,DC=example,DC=local
LDAP_BIND_PASSWORD=
# Alternativa al password literal (recomendado si tiene chars especiales):
# echo -n "secret" | base64
# LDAP_BIND_PASSWORD_B64=
LDAP_USE_STARTTLS=true
LDAP_TIMEOUT=10

# ===== Wazuh webhook =====
# Generar con: openssl rand -hex 32
# El mismo valor va en <api_key> del integrator de Wazuh (ossec.conf)
WAZUH_WEBHOOK_SECRET=

# ===== OpenAI =====
OPENAI_API_KEY=
OPENAI_MODEL_LIGHT=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o

# ===== Wazuh manager API (Enricher tool) =====
WAZUH_API_HOST=127.0.0.1
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=
# false = aceptar self-signed cert (default en deploys on-prem)
WAZUH_API_VERIFY_SSL=false

# ===== SMTP (email de aprobación del Narrator) =====
# Exchange 2016 / O365: STARTTLS en 587. Para hosts con self-signed, dejar SSL_VERIFY=false.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=soc-l1@example.local
# Lista de destinatarios separados por coma:
SMTP_TO_APPROVERS=
SMTP_USE_STARTTLS=true
SMTP_SSL_VERIFY=false

# ===== Approval workflow =====
# URL pública que aparece en los links del email. Tiene que ser alcanzable desde
# los browsers de los analistas (puede ser IP interna si solo usan la red corporativa).
APPROVAL_BASE_URL=http://localhost:8000
APPROVAL_TTL_HOURS=24
# Path persistente para SQLite (asegurar que el user que corre el servicio tenga write).
STATE_DB_PATH=/var/lib/soc-l1/state.db

# ===== FortiGate (futuro) =====
# FORTIGATE_HOST=192.0.2.1:4343
# FORTIGATE_TOKEN=

# ===== Threat Intel (ThreatIntel agent) =====
# VirusTotal API v3 - signup en virustotal.com, free tier = 500 lookups/día, 4/min
VIRUSTOTAL_API_KEY=
# AbuseIPDB API v2 - signup en abuseipdb.com, free tier = 1000 checks/día
ABUSEIPDB_API_KEY=

# ===== Servicio HTTP =====
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
LOG_LEVEL=INFO

# ===== Guardrails de ejecución =====
# Lista de cuentas que el executor REFUSA tocar, sin importar si el approval se clickeó.
# Comma-separated, case-insensitive. Incluí siempre admins, service accounts, ejecutivos.
PROTECTED_USERS=jdoe,admin,svc-soar,wazuhseg

# Si true, executor NO ejecuta acciones AD reales - solo logea como "DRY_RUN: ...".
# Útil mientras validás el Narrator. Dejarlo true hasta tener confianza en las recomendaciones.
DRY_RUN_MODE=true

# ===== Feature flags =====
# Activar progresivamente en producción:
ENABLE_TRIAGE=true
ENABLE_ENRICHER=true
ENABLE_THREAT_INTEL=true
ENABLE_NARRATOR=true
