# SMTP_USER=soar
# SMTP_PASSWORD=
# SMTP_FROM=SOC SOAR <soar@example.com>
# SOC_APPROVER_EMAIL=analyst@example.com
# SOC_TEAM_EMAIL=soc-team@example.com

# ===== Servicio HTTP =====
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
LOG_LEVEL=INFO
